# ── Database ──────────────────────────────────────────────────────────────────
# Accepts either a postgres:// URL or an Npgsql key=value string
# Option A — URL format (Neon, Heroku, Railway, Render, etc.)
ConnectionStrings__POSTGRES_CONNECTION_STRING=postgresql://user:password@host/database?sslmode=require
# Option B — Npgsql key=value format
# ConnectionStrings__POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=fourplay;Username=postgres;Password=changeme

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32-character secret; use a random value in production
Jwt__Key=change-me-to-a-long-random-secret-at-least-32-chars
Jwt__Issuer=FourPlayWebApp
Jwt__Audience=FourPlayWebAppClient
Jwt__ExpiresMinutes=60

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# https://support.google.com/accounts/answer/185833
FOURPLAY_EMAIL_USER=yourapp@gmail.com
FOURPLAY_EMAIL_PASS=your-gmail-app-password

# ── Admin seed account ────────────────────────────────────────────────────────
# Created automatically on first startup by UserManagerJob
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Change-Me-Strong-Password1!

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://yourapp.example.com
ASPNETCORE_ENVIRONMENT=Production
