{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build server",
      "program": "${workspaceFolder}/Server/bin/Debug/net9.0/FourPlayWebApp.Server.dll",
      "cwd": "${workspaceFolder}/Server",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "React (Vite)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/Client.React",
      "preLaunchTask": "dev react"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Server + React)",
      "configurations": ["Server (.NET)", "React (Vite)"]
    }
  ]
}
